# Mobile public configuration. Values prefixed with EXPO_PUBLIC_ are visible to clients.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GATEWAY_URL=http://localhost:4310
EXPO_PUBLIC_ENABLE_JACOO=false
# Public browser values. Restrict allowed domains in the AMap console.
EXPO_PUBLIC_AMAP_KEY=
EXPO_PUBLIC_AMAP_SECURITY_JS_CODE=

# Gateway-only development configuration. Never expose these values to the mobile app.
PF_ENABLE_JACOO=false
JACOO_BASE_URL=
JACOO_API_KEY=
PF_ALLOWED_ORIGIN=http://localhost:8081
PORT=4310

# Independent device-status admin. Keep credentials and tokens server-only.
ADMIN_HOST=0.0.0.0
ADMIN_PORT=4311
PF_ADMIN_USERNAME=operator
PF_ADMIN_PASSWORD=
PF_DEVICE_HEARTBEAT_TOKEN=
# Optional comma-separated exact origins. Defaults to the admin request hostname.
PF_WEB_ORIGIN=
VITE_ADMIN_URL=
