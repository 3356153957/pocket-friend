# Mobile public configuration. Values prefixed with EXPO_PUBLIC_ are visible to clients.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GATEWAY_URL=http://localhost:4310
EXPO_PUBLIC_ENABLE_JACOO=false

# Gateway-only development configuration. Never expose these values to the mobile app.
PF_ENABLE_JACOO=false
JACOO_BASE_URL=
JACOO_API_KEY=
PF_ALLOWED_ORIGIN=http://localhost:8081
PORT=4310
