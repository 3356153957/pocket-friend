{
  "name": "pocket-friend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test packages/nearby-core/test/*.test.ts apps/gateway/test/*.test.ts apps/mobile/test/*.test.ts",
    "test:deploy": "node --test scripts/test/deploy-production.test.mjs",
    "test:core": "node --experimental-strip-types --test packages/nearby-core/test/*.test.ts",
    "typecheck": "tsc -b",
    "dev:mobile": "npm run start --workspace @pf/mobile",
    "dev:gateway": "npm run dev --workspace @pf/gateway",
    "build:web": "npm run build:web --workspace @pf/mobile",
    "build:sites": "npm run build:web --workspace @pf/mobile && node scripts/prepare-sites-static.mjs"
  },
  "engines": {
    "node": ">=22.18"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "typescript": "5.8.3"
  }
}
