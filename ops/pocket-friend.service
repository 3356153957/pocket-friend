[Unit]
Description=Pocket Friend static web app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/srv/pocket-friend/current
Environment=HOST=::
Environment=PORT=80
Environment=POCKET_FRIEND_STATIC_ROOT=/srv/pocket-friend/current
ExecStart=/usr/bin/node /root/pocket-friend-static-server.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
